let day=['Воскресенье','Понедельник','Вторник','Среда','Четверг','Пятница','Суббота'][new Date().getDay()];if(day==='Воскресенье')day='Понедельник';function bells(d){return d==='Пятница'?BF:BD}function tm(t){let a=t.split(':').map(Number);return a[0]*60+a[1]}function mt(n){n=Math.max(0,n);let h=Math.floor(n/60),m=n%60;return h&&m?h+' ч '+m+' мин':h?h+' ч':m+' мин'}function rooms(){return JSON.parse(localStorage.getItem('rooms')||'{}')}function key(c,d,i){return c+'|'+d+'|'+i}function rm(c,d,i,b){return rooms()[key(c,d,i)]||b||''}function fill(){cls.innerHTML=LEVELS[level.value].map(c=>`<option>${c}</option>`).join('');let sv=localStorage.getItem('className');if(sv&&LEVELS[level.value].includes(sv))cls.value=sv;render()}level.onchange=fill;cls.onchange=()=>{localStorage.setItem('className',cls.value);render()};function inf(ls,d){let b=bells(d).slice(0,ls.length),n=new Date(),m=n.getHours()*60+n.getMinutes();for(let i=0;i<b.length;i++){let s=tm(b[i][0]),e=tm(b[i][1]);if(m>=s&&m<=e)return{t:'lesson',i,rem:e-m,total:e-s,pass:m-s,next:i+1};if(i<b.length-1){let bs=e,be=tm(b[i+1][0]);if(m>bs&&m<be)return{t:'break',i,rem:be-m,total:be-bs,pass:m-bs,next:i+1}}}let nx=b.findIndex(x=>tm(x[0])>m);return{t:'none',i:-1,rem:0,total:1,pass:0,next:nx}}function tabs(){tabsEl=document.getElementById('tabs');tabsEl.innerHTML=D.map(d=>`<div class="tab ${d===day?'active':''}" onclick="day='${d}';render()">${d}</div>`).join('')}function txt(c,d,l,i){let r=rm(c,d,i,l[1]);return r?l[0]+' • '+r:l[0]}function render(){tabs();rday.innerHTML=D.map(d=>`<option>${d}</option>`).join('');rles.innerHTML=Array.from({length:8},(_,i)=>`<option value="${i+1}">${i+1}</option>`).join('');let c=cls.value,ls=S[c]?.[day]||[];if(!S[c]){now.textContent='В разработке';room.textContent='Появится в патче';timer.textContent='—';tl.textContent='скоро';next.textContent='Скоро';circle.style.setProperty('--angle','0deg');box.innerHTML='<p class="muted">Этот класс будет добавлен позже.</p>';return}let x=inf(ls,day),b=bells(day).slice(0,ls.length);circle.style.setProperty('--angle',(Math.min(1,Math.max(0,x.pass/x.total))*360)+'deg');if(x.t==='lesson'&&ls[x.i]){let l=ls[x.i];now.textContent=l[0];room.textContent=rm(c,day,x.i,l[1])||'каб. не указан';timer.textContent=mt(x.rem);tl.textContent='до конца';next.textContent=ls[x.next]?txt(c,day,ls[x.next],x.next):'Следующего урока нет'}else if(x.t==='break'){now.textContent='Перемена';room.textContent='следующий урок скоро';timer.textContent=mt(x.rem);tl.textContent='до урока';next.textContent=ls[x.next]?txt(c,day,ls[x.next],x.next):'Уроков больше нет'}else{now.textContent='Уроков сейчас нет';room.textContent=day;timer.textContent='—';tl.textContent='сейчас';next.textContent=ls[x.next]?txt(c,day,ls[x.next],x.next):'На сегодня всё'}box.innerHTML=ls.length?ls.map((l,i)=>{let cur=x.t==='lesson'&&x.i===i?'current':'',time=b[i]?b[i][0]+'–'+b[i][1]:'—',r=rm(c,day,i,l[1]);return `<div class="lesson ${cur}"><div class="num">${i+1}</div><div><b>${l[0]}</b><br><small>${time}</small></div><div class="pill">${r||'—'}</div></div>`}).join(''):'<p class="muted">Уроков нет.</p>'}function saveRoom(){let c=cls.value,d=rday.value,i=Number(rles.value)-1,r=rin.value.trim();if(!r){alert('Введи кабинет');return}let rs=rooms();rs[key(c,d,i)]=r;localStorage.setItem('rooms',JSON.stringify(rs));rin.value='';render()}function go(id){document.getElementById(id).scrollIntoView({behavior:'smooth'})}fill();setInterval(render,30000);
