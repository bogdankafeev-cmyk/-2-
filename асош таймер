dius:42px;background:#000;padding:12px;box-shadow:18px 22px 0 #222;transform:rotate(2deg)}@media(max-width:520px){.phone{transform:none}.qrbox{grid-template-columns:1fr}.qr{width:160px;height:160px}}.screen{border:1px solid #333;border-radius:30px;padding:16px;background:#070709;min-height:620px}.bar{display:flex;justify-content:space-between;font-weight:900;margin-bottom:14px}.selects{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}select,input,button{width:100%;border:0;border-radius:16px;padding:12px;font-size:15px;font-family:inherit}select,input{background:#fff;color:#000;font-weight:800}button{background:#fff;color:#000;font-weight:900}.now,.next{background:#111;border:1px solid #333;border-radius:22px;padding:14px;margin-bottom:12px}.label{font-size:13px;font-weight:900;color:#aaa;letter-spacing:1px}.subj{font-size:28px;font-weight:900}.circle{width:144px;height:144px;border-radius:50%;display:grid;place-items:center;margin:12px auto;background:conic-gradient(#fff var(--angle),#29292e 0)}.circlein{width:112px;height:112px;border-radius:50%;background:#08080a;border:1px solid #333;display:grid;place-items:center;text-align:center}.timer{font-size:28px;font-weight:900}.apps{display:grid;grid-template-columns:1fr 1fr;gap:10px}.app{min-height:82px;border-radius:20px;background:#fff;color:#000;display:grid;place-items:center;text-align:center;font-weight:900}.app span{font-size:25px;display:block}.tabs{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}.tab{border:1px solid #333;border-radius:999px;padding:9px 12px;cursor:pointer;font-weight:900;background:#111}.tab.active{background:#fff;color:#000}.lesson{display:grid;grid-template-columns:44px 1fr auto;gap:10px;align-items:center;padding:12px;border-bottom:1px solid #29292d}.lesson.current{background:#fff;color:#000;border-radius:16px}.num{width:38px;height:38px;border-radius:50%;border:2px solid currentColor;display:grid;place-items:center;font-weight:900}.pill{border:1px solid currentColor;border-radius:999px;padding:6px 8px;font-weight:900;white-space:nowrap}.foot{display:flex;gap:12px;flex-wrap:wrap;justify-content:space-between;align-items:center;border-top:2px solid #fff;margin-top:18px;padding-top:16px;font-weight:900}.slogan{font-size:clamp(24px,4vw,40px);background:#fff;color:#000;padding:8px 14px;transform:skew(-4deg)}</style></head><body><div class="wrap"><div class="poster"><div class="top"><div class="brand">АСОШ №2</div><div class="beta">BETA</div></div><h1>Школа в твоём <span>кармане</span></h1><p class="subtitle">Умное приложение для учеников 5–11 классов</p><div class="grid"><div><div class="card"><div class="title">Всё, что нужно ученику</div><div class="feat"><div class="ico">⏱</div><div><b>Таймер уроков</b><p class="muted">Следи за временем уроков и перемен.</p></div></div><div class="feat"><div class="ico">▦</div><div><b>Расписание</b><p class="muted">Актуальное расписание твоего класса.</p></div></div><div class="feat"><div class="ico">🔔</div><div><b>Уведомления</b><p class="muted">Не пропусти важное.</p></div></div><div class="feat"><div class="ico">✓</div><div><b>Домашние задания</b><p class="muted">Записывай, не забывай, успевай.</p></div></div><div class="feat"><div class="ico">👤</div><div><b>Профиль</b><p class="muted">Твой личный кабинет.</p></div></div></div><div class="card qrbox"><img class="qr" src="qr.png"><div><div class="cta">Напиши<br>и скачай<br>первым!</div><p class="muted">Отсканируй QR-код и переходи в приложение.</p></div></div><div class="card"><div class="title">Классы</div><p class="muted">Сейчас добавлены 5А, 5Б, 5В и 5Г. Остальные классы добавим патчами.</p></div></div><div><div class="phone"><div class="screen"><div class="bar"><span>АСОШ №2</span><span>◔</span></div><div class="selects"><select id="level"><option value="middle">Средняя</option><option value="primary">Начальная</option><option value="high">Старшая</option></select><select id="cls"></select></div><div class="now"><div class="label">СЕЙЧАС</div><div class="circle" id="circle"><div class="circlein"><div><div class="timer" id="timer">—</div><div class="label" id="tl">таймер</div></div></div></div><div class="subj" id="now">—</div><b id="room">—</b></div><div class="next"><div class="label">ДАЛЕЕ</div><b id="next">—</b></div><div class="apps"><div class="app" onclick="go('sch')"><div><span>▦</span>Расписание</div></div><div class="app" onclick="go('edit')"><div><span>🏫</span>Кабинет</div></div><div class="app" onclick="go('future')"><div><span>🚀</span>Будущее</div></div><div class="app" onclick="go('about')"><div><span>👤</span>Профиль</div></div></div></div></div><div class="card" id="sch"><div class="title">Расписание</div><div id="tabs" class="tabs"></div><div id="box"></div></div><div class="card" id="edit"><div class="title">Редактор кабинета</div><p class="muted">Можно вручную исправить кабинет.</p><div class="selects"><select id="rday"></select><select id="rles"></select></div><input id="rin" placeholder="Например: 327"><button onclick="saveRoom()" style="margin-top:10px">Сохранить</button></div><div class="card" id="about"><div class="title">О проекте</div><p class="muted">Бета-версия приложения АСОШ №2: расписание, таймер, кабинеты, домашние задания и уведомления.</p></div><div class="card" id="future"><div class="title">Будущее</div><p class="muted">Новые классы, домашние задания, уведомления, профиль и онлайн-режим.</p></div></div></div><div class="foot"><div class="slogan">Учись. Планируй. Успевай!</div><div>АСОШ №2 • 5–11 классы • Beta</div></div></div></div><script>
const LEVELS={primary:['1А','1Б','2А','2Б','3А','3Б','4А','4Б'],middle:['5А','5Б','5В','5Г','6А','6Б','6В','6Г','7А','7Б','8А','8Б','8В','8Г','9А','9Б','9В'],high:['10А','10Б','11А','11Б']};
const D=['Понедельник','Вторник','Среда','Четверг','Пятница','Суббота'],BD=[['13:45','14:25'],['14:35','15:15'],['15:25','16:05'],['16:15','16:55'],['17:05','17:45'],['17:50','18:30'],['18:35','19:15']],BF=[['13:00','13:40'],['13:50','14:30'],['14:40','15:20'],['15:30','16:10'],['16:20','17:00'],['17:10','17:50'],['18:00','18:40']];
const S={
'5А':{'Понедельник':[['Разговор о важном','по назначению'],['Ин.яз','214 / 108'],['Информатика','323'],['Русский','106'],['Математика','327'],['Литература','106'],['Музыка','актовый зал']],'Вторник':[['История','327'],['Русский','330'],['Технология','кабинет трудов / столовая'],['Технология','кабинет трудов / столовая'],['Математика','329'],['Ин.яз','214 / 108']],'Среда':[['Литература','217'],['Русский','108'],['Математика','106'],['ФЗК','спортзал'],['Биология','209']],'Четверг':[['Литература','217'],['Математика','324'],['География','329'],['Русский','330'],['ИЗО','106'],['История','332'],['Проф.мин','по назначению']],'Пятница':[['История','108'],['Русский','209'],['Ин.яз','214 / 108'],['Математика','324'],['ФЗК','спортзал']],'Суббота':[]},
'5Б':{'Понедельник':[['Разговор о важном','по назначению'],['Информатика','323'],['Математика','327'],['Ин.яз','327'],['Русский','106'],['Музыка','актовый зал'],['Литература','106']],'Вторник':[['Математика','324'],['История','327'],['Русский','330'],['Литература','330'],['Технология','рядом с 108'],['Технология','рядом с 108']],'Среда':[['Ин.яз','332'],['Русский','108'],['Математика','106'],['ФЗК','спортзал'],['Биология','209']],'Четверг':[['История','329'],['Математика','324'],['География','329'],['Русский','330'],['Ин.яз','327'],['Проф.мин','по назначению']],'Пятница':[['Литература','323'],['Русский','209'],['ФЗК','спортзал'],['Математика','324'],['История','108'],['ИЗО','106']],'Суббота':[]},
